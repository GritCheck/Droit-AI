# =============================================================================
# AZURE ACTIVE DIRECTORY (OBO FLOW) CONFIGURATION
# =============================================================================
# Application Registration Details (Azure AD)
AZURE_CLIENT_ID=your-azure-ad-application-client-id
AZURE_CLIENT_SECRET=your-azure-ad-application-client-secret
AZURE_TENANT_ID=your-azure-ad-tenant-id

# OBO Flow Specific Configuration
AZURE_AUTHORITY=https://login.microsoftonline.com/
AZURE_SCOPES=api://your-backend-app-id/access_as_user
BACKEND_API_SCOPE=api://your-backend-app-id/access_as_user

# Frontend Auth Configuration (NextAuth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secure-nextauth-secret-min-32-chars
AZURE_AD_CLIENT_ID=${AZURE_CLIENT_ID}
AZURE_AD_TENANT_ID=${AZURE_TENANT_ID}
AZURE_AD_CLIENT_SECRET=${AZURE_CLIENT_SECRET}

# =============================================================================
# AZURE AI SERVICES CONFIGURATION
# =============================================================================

# Azure AI Search (Vector Database)
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_KEY=your-azure-search-admin-key
AZURE_SEARCH_INDEX_NAME=rag-index
AZURE_SEARCH_INDEX_NAME_CHAT=rag-chat-history
AZURE_SEARCH_SEMANTIC_CONFIGURATION=semantic-config

# Azure OpenAI (Chat & Embeddings)
AZURE_OPENAI_ENDPOINT=https://your-openai-service.openai.azure.com/
AZURE_OPENAI_API_KEY=your-openai-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure Document Intelligence (OCR & Document Parsing)
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://your-doc-intelligence-service.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_KEY=your-doc-intelligence-key
AZURE_DOC_INTELLIGENCE_API_VERSION=2023-10-31-preview

# Azure Content Safety (Responsible AI)
AZURE_CONTENT_SAFETY_ENDPOINT=https://your-content-safety-service.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_KEY=your-content-safety-key

# =============================================================================
# AZURE STORAGE & DATABASE CONFIGURATION
# =============================================================================

# Azure Cosmos DB (Chat History & Session State)
COSMOS_DB_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_DB_KEY=your-cosmos-db-master-key
COSMOS_DB_DATABASE_NAME=rag-chat
COSMOS_DB_CONTAINER_NAME=chat-history
COSMOS_DB_SESSION_CONTAINER_NAME=sessions

# Azure Blob Storage (Document Uploads)
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
AZURE_STORAGE_ACCESS_KEY=your-storage-access-key
AZURE_STORAGE_CONTAINER_NAME=documents
AZURE_STORAGE_CONTAINER_NAME_PROCESSED=processed-docs

# =============================================================================
# APPLICATION & DEVELOPMENT CONFIGURATION
# =============================================================================

# Service URLs (for Docker networking)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
BACKEND_INTERNAL_URL=http://backend:8000

# Feature Toggles (Governance Controls)
ENABLE_LOCAL_PARSING=false
ENABLE_AZURE_DOC_INTELLIGENCE=true
ENABLE_CONTENT_SAFETY=true
ENABLE_DETAILED_LOGGING=false
ENABLE_METRICS=true

# Local Development Configuration
LOCAL_DOCS_PATH=./data/raw
LOCAL_PROCESSED_PATH=./data/processed
REDIS_PASSWORD=redis123
COSMOS_DB_EMULATOR=false

# =============================================================================
# DEVELOPMENT & TESTING CONFIGURATION
# =============================================================================

# Environment Settings
NODE_ENV=development
PYTHON_ENV=development
DEBUG=true
LOG_LEVEL=info

# Testing Configuration
ENABLE_MOCK_RESPONSES=false
TEST_MODE=false

# =============================================================================
# SECURITY & COMPLIANCE
# =============================================================================

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-for-session-management
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Application Insights (Optional)
APPLICATIONINSIGHTS_CONNECTION_STRING=your-app-insights-connection-string

# Prometheus Metrics (Optional)
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
